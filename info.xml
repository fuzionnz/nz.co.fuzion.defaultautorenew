<?xml version="1.0"?>
<extension key="nz.co.fuzion.defaultautorenew" type="module">
  <file>defaultautorenew</file>
  <name>Make Auto-renew the default option</name>
  <description>Automatically checks the Auto-renew checkbox by default on contribution pages for membership types that support auto-renew.</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Jitendra Purohit</author>
    <email>jitendra@fuzion.co.nz</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://github.com/fuzionnz/nz.co.fuzion.defaultautorenew</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2025-01-01</releaseDate>
  <version>2.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>5.0</ver>
    <ver>6.0</ver>
  </compatibility>
  <comments>Compatible with CiviCRM 5.x, 6.x and PHP 8.1+</comments>
  <civix>
    <namespace>CRM/Defaultautorenew</namespace>
  </civix>
</extension>
